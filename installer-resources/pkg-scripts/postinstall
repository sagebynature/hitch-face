#!/bin/bash
set -u

APP_RESOURCES="/Applications/Hitch Face.app/Contents/Resources/hitch-face"
INSTALL_HELPER="$APP_RESOURCES/install-extension.js"
CONSOLE_USER="$(stat -f '%Su' /dev/console 2>/dev/null || true)"

if [ -n "$CONSOLE_USER" ] && [ "$CONSOLE_USER" != "root" ]; then
  TARGET_HOME="$(dscl . -read "/Users/$CONSOLE_USER" NFSHomeDirectory 2>/dev/null | awk '{print $2}')"
else
  TARGET_HOME="$HOME"
fi

if ! command -v node >/dev/null 2>&1; then
  echo "Hitch Face installed, but Node.js was not found."
  echo "Install Node.js 22.12+ so Hitch can run the Hitch Face adapter."
  exit 0
fi

if [ ! -f "$INSTALL_HELPER" ]; then
  echo "Hitch Face extension helper not found at $INSTALL_HELPER"
  exit 0
fi

node "$INSTALL_HELPER" --home "$TARGET_HOME" || true

if [ -d /usr/local/bin ] && [ -w /usr/local/bin ]; then
  cat > /usr/local/bin/hitch-face <<'EOF'
#!/bin/bash
exec open -a "Hitch Face" --args "$@"
EOF
  chmod +x /usr/local/bin/hitch-face
else
  echo "Skipping /usr/local/bin/hitch-face launcher; /usr/local/bin is not writable."
fi

exit 0
